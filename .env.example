# Supabase credentials
# Get these from your Supabase project dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# IMPORTANT: Never put the service role key in client code.
# RLS policies require the migration in supabase/migrations/001_initial_schema.sql to be applied.

# OAuth providers (for Supabase local dev — set these in supabase/.env or system env)
# Google: Create at https://console.cloud.google.com/apis/credentials
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-client-secret

# Apple: Create at https://developer.apple.com/account/resources/identifiers
SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=com.dwella.app
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=your-apple-secret-key
